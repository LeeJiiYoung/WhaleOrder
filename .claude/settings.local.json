{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/save-conversation.js\"",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(mkdir -p E:/Cardnews/order/src/main/java/com/whale/order/global/config)",
      "Bash(mkdir -p E:/Cardnews/order/src/main/java/com/whale/order/global/exception)",
      "Bash(mkdir -p E:/Cardnews/order/src/main/java/com/whale/order/global/response)",
      "Bash(mkdir -p E:/Cardnews/order/src/main/java/com/whale/order/global/util)",
      "Bash(mkdir -p E:/Cardnews/order/src/main/java/com/whale/order/domain/member/controller)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Bash(xargs grep *)",
      "Bash(git -C e:/WhaleOrder status --short)",
      "Bash(git -C e:/WhaleOrder ls-files order/)",
      "Bash(git -C e:/WhaleOrder ls-files \"order/order/\")",
      "Bash(git -C e:/WhaleOrder ls-files \"order/.idea/\" \"order/uploads/\" \"order/order/\" \"order/bin/\")",
      "Bash(git rm *)",
      "Bash(git mv *)",
      "PowerShell(Get-ExecutionPolicy -List)",
      "Bash(./gradlew compileJava --quiet)",
      "Bash(grep -E \"\\\\.\\(java\\)$\")",
      "Bash(xargs ls -la)",
      "Bash(git *)",
      "PowerShell(Get-Process | Where-Object { $_.MainWindowTitle -ne \"\" -or $_.Name -match \"node|npm|vite|java\" } | Select-Object Id, Name, MainWindowTitle)",
      "Bash(./gradlew compileJava)",
      "Bash(./gradlew test *)",
      "Bash(grep -E \"src/main.*\\\\.java$\")",
      "Bash(grep -E \"\\\\.java$\")"
    ]
  }
}
