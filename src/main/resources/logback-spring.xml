<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="order"/>

    <!-- 콘솔 출력 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan([%15.15t]) %yellow(%-40.40logger{39}) : %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 파일 출력 (날짜별 롤링) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/order.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/order.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 30일치 보관 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%t] %logger{36} : %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 비즈니스 로그만 따로 수집 -->
    <appender name="BIZ_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/biz.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/biz.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} : %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 비즈니스 로그 (주문/재고 흐름) -->
    <logger name="com.whale.order.domain.order.service.OrderService"   level="INFO" additivity="true">
        <appender-ref ref="BIZ_FILE"/>
    </logger>
    <logger name="com.whale.order.domain.stock.service.StockService"   level="INFO" additivity="true">
        <appender-ref ref="BIZ_FILE"/>
    </logger>
    <logger name="com.whale.order.domain.stock.service.StockLockFacade" level="INFO" additivity="true">
        <appender-ref ref="BIZ_FILE"/>
    </logger>
    <logger name="com.whale.order.domain.order.service.OrderProcessingService" level="INFO" additivity="true">
        <appender-ref ref="BIZ_FILE"/>
    </logger>
    <logger name="com.whale.order.domain.order.service.OrderKafkaConsumer" level="INFO" additivity="true">
        <appender-ref ref="BIZ_FILE"/>
    </logger>

    <!-- HTTP 요청 로그 -->
    <logger name="com.whale.order.global.filter.RequestLoggingFilter" level="INFO" additivity="true">
        <appender-ref ref="BIZ_FILE"/>
    </logger>

    <!-- 외부 라이브러리 노이즈 억제 -->
    <logger name="org.hibernate.SQL"                          level="DEBUG"/>
    <logger name="org.hibernate.orm.jdbc.bind"                level="TRACE"/>
    <logger name="org.apache.kafka"                           level="WARN"/>
    <logger name="org.springframework.kafka"                  level="WARN"/>
    <logger name="io.lettuce"                                 level="WARN"/>
    <logger name="org.redisson"                               level="WARN"/>

    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

</configuration>
